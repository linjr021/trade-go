# ===== 部署 / 容器 =====
COMPOSE_PROJECT_NAME=trade-go
BACKEND_PORT=8080
FRONTEND_PORT=5173
APP_UID=1000
APP_GID=1000

# 构建代理（可选，默认官方源）
GO_PROXY=https://proxy.golang.org,direct
GO_SUMDB=sum.golang.org
NPM_REGISTRY=https://registry.npmjs.org

# ===== 基础运行 =====
PRODUCT_NAME=21xG
MODE=web
HTTP_ADDR=:8080
TRADE_DB_PATH=data/trade.db

# 首次初始化管理员密码（可选；留空表示不预置）
ADMIN_INITIAL_PASSWORD=

# ===== Cloudflare Tunnel（可选）=====
# 使用 docker compose --profile tunnel 启动 cloudflared 时生效
CF_TUNNEL_ENABLED=auto
CF_TUNNEL_TOKEN=

# ===== 智能体 =====
# AI_PRODUCT: chatgpt / deepseek / glm / qwen / minimax
AI_PRODUCT=chatgpt
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=
AI_EXECUTION_STRATEGIES=

# 可选：直接覆盖工作流注入的决策提示词
TRADING_AI_SYSTEM_PROMPT=
TRADING_AI_POLICY_PROMPT=

# 可选：策略生成链路 LLM 开关与超时
STRATEGY_LLM_ENABLED=true
STRATEGY_LLM_TIMEOUT_SEC=45

# ===== 交易所 =====
ACTIVE_EXCHANGE=binance

# Binance
BINANCE_API_KEY=
BINANCE_SECRET=

# OKX
OKX_API_KEY=
OKX_SECRET=
OKX_PASSWORD=

# ===== 交易参数 =====
TRADE_SYMBOL=BTCUSDT
TRADE_AMOUNT=0.01
POSITION_SIZING_MODE=margin_pct
HIGH_CONFIDENCE_AMOUNT=0.01
LOW_CONFIDENCE_AMOUNT=0.00
HIGH_CONFIDENCE_MARGIN_PCT=0.05
LOW_CONFIDENCE_MARGIN_PCT=0.00
LEVERAGE=20
TIMEFRAME=15m
DATA_POINTS=96
TEST_MODE=false

# 可选：技术指标周期
SHORT_TERM_PERIOD=20
MEDIUM_TERM_PERIOD=50
LONG_TERM_PERIOD=96

# ===== 风控参数 =====
MAX_RISK_PER_TRADE_PCT=0.01
MAX_POSITION_PCT=0.20
MAX_CONSECUTIVE_LOSSES=3
MAX_DAILY_LOSS_PCT=0.05
MAX_DRAWDOWN_PCT=0.12
LIQUIDATION_BUFFER_PCT=0.02

# ===== 实时触发 =====
ENABLE_WS_MARKET=true
REALTIME_MIN_INTERVAL_SEC=10

# ===== 自动评估 =====
AUTO_REVIEW_ENABLED=true
AUTO_REVIEW_AFTER_ORDER_ONLY=true
AUTO_REVIEW_INTERVAL_SEC=1800
AUTO_REVIEW_VOLATILITY_PCT=1.2
AUTO_REVIEW_DRAWDOWN_WARN_PCT=0.05
AUTO_REVIEW_LOSS_STREAK_WARN=2
AUTO_REVIEW_RISK_REDUCE_FACTOR=0.7

# ===== 自动策略重生成 =====
AUTO_STRATEGY_REGEN_ENABLED=true
AUTO_STRATEGY_REGEN_COOLDOWN_SEC=21600
AUTO_STRATEGY_REGEN_LOSS_STREAK=3
AUTO_STRATEGY_REGEN_DRAWDOWN_WARN_PCT=0.08
AUTO_STRATEGY_REGEN_MIN_RR=2.0
